DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
MOD_LOG_CHANNEL_ID=
REPORT_CHANNEL_ID=
TASK_MANAGER_ROLE_IDS=

# ==========================================
# Smart Penalty & Auto Moderation System
# ==========================================

# Enable auto moderation (bad word detection)
AUTO_MOD_ENABLED=true

# If true, bot will auto kick users at SP2 threshold
# If false, bot will only recommend kick in log channel
AUTO_KICK_ENABLED=false

# Penalty point thresholds
PENALTY_NORMAL_THRESHOLD=30
PENALTY_SP_THRESHOLD=20

# Auto decay settings (runs every 30 minutes)
PENALTY_DECAY_HOURS=3
PENALTY_DECAY_POINTS=2

# Good report reduction points
GOOD_REPORT_REDUCTION_POINTS=3

# Default points for bad word violation
BAD_WORD_DEFAULT_POINTS=3

# Auto delete messages containing bad words
AUTO_DELETE_BAD_WORD_MESSAGE=true