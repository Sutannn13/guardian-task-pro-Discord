# ========================================
# GuardianTask Pro - Environment Variables
# ========================================

# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Channel IDs (Optional - bot akan tetap berjalan tanpa ini)
MOD_LOG_CHANNEL_ID=
REPORT_CHANNEL_ID=

# Task Manager Role IDs (pisahkan dengan koma jika lebih dari satu)
TASK_MANAGER_ROLE_IDS=
